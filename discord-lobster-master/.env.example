# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Gemini API Key (free: https://aistudio.google.com/apikeys)
GEMINI_API_KEY=

# Your Discord Server (Guild) ID
GUILD_ID=

# Channel IDs (right-click channel → Copy Channel ID)
WELCOME_CHANNEL_ID=
GENERAL_CHANNEL_ID=
ASK_CHANNEL_ID=

# Discord Webhook URLs (Server Settings → Integrations → Webhooks)
# Create one webhook per channel where the lobster should post
WELCOME_WEBHOOK_URL=
GENERAL_WEBHOOK_URL=

# Lobster identity
BOT_NAME=Lobster CEO 🦞
BOT_AVATAR_URL=

# ── Phase 3 新增腳本所需變數 ──────────────────────────────────────────

