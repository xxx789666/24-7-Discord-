# Arthur Bot 排程 — 自動產生於 2026-03-31 09:02
# 環境變數
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/home/training/.nvm/versions/node/v20.20.2/bin

# ─────────────────────────────────────────────
